{
  "name": "heavy-erp-desktop",
  "version": "2.0.0",
  "private": true,
  "description": "Electron desktop launcher for Heavy ERP",
  "main": "electron/main.cjs",
  "scripts": {
    "desktop": "electron .",
    "electron": "electron .",
    "frontend:build": "node react-src/node_modules/vite/bin/vite.js build --config react-src/vite.config.js",
    "backend:init": "python -m app.desktop",
    "backend:seed": "python -m app.desktop --seed-demo"
  },
  "devDependencies": {
    "electron": "^31.7.7"
  }
}
